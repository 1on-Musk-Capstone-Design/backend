# IDE에서 서버만 실행할 때(cwd 가 Capstone 루트가 아닐 때) OpenAI 키를 읽으려면:
#   cp src/main/resources/application-local.yml.example src/main/resources/application-local.yml
#   아래 api-key 를 platform.openai.com 에서 발급한 sk-... 로 교체
# application-local.yml 은 .gitignore 되어 커밋되지 않습니다.

openai:
  api-key: your-openai-api-key-here
  # prototype-model: gpt-4o-mini

# GitHub 없이 Vercel API로 직접 배포합니다. (비우면 PRD 생성만 동작)
app:
  prototype:
    # vercel-token: your-vercel-token
    # vercel-team-id: team_xxx
