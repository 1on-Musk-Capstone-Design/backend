# coturn example configuration for cross-network voice chat
# Copy this file to turnserver.conf and replace the placeholders before starting coturn.

listening-port=3478
tls-listening-port=5349
fingerprint
lt-cred-mech

# Match these values with frontend/.env or frontend/.env.example
realm=YOUR_TURN_HOST_OR_DOMAIN
server-name=YOUR_TURN_HOST_OR_DOMAIN
user=YOUR_TURN_USERNAME:YOUR_TURN_PASSWORD

# If the server sits behind NAT, use PUBLIC_IP/PRIVATE_IP format.
# If the machine has a public IP directly, set only the public address.
external-ip=YOUR_PUBLIC_IP_OR_PUBLIC_IP/PRIVATE_IP

# Relay port range should be opened in the firewall and security group.
min-port=49160
max-port=49200

no-multicast-peers
no-loopback-peers
stale-nonce
simple-log
syslog

# Uncomment these if you enable TLS with a real certificate.
#cert=/etc/letsencrypt/live/YOUR_TURN_HOST_OR_DOMAIN/fullchain.pem
#pkey=/etc/letsencrypt/live/YOUR_TURN_HOST_OR_DOMAIN/privkey.pem