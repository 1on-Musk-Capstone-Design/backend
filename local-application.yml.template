# ── 로컬 OpenAI 설정 ─────────────────────────────────────────────
# 사용법 (Capstone 프로젝트 루트에서):
#   cp local-application.yml.template local-application.yml
#   편집기로 local-application.yml 을 열어 api-key 에 platform.openai.com 에서 발급한 키만 넣으세요.
#   (sk- 로 시작하는 영문·숫자·-_. 만 포함. 한글 설명을 키 값에 넣으면 OpenAI가 비활성화됩니다.)
# local-application.yml 은 .gitignore 되어 커밋되지 않습니다.
#
# (A) 이 파일 — 서버 기동 디렉터리가 Capstone 루트일 때 로드
# (B) src/main/resources/application-local.yml — IDE에서 Run 시 cwd 와 무관(권장). 예시: application-local.yml.example 복사
# PRD 파이프라인 실행 후 platform.openai.com Keys 의 Last used 가 갱신되면 연결 성공입니다.

# 로컬 DB / JWT — 저장소에 올리지 말고 이 파일에만 두세요.
spring:
  jwt:
    secret: local-dev-jwt-secret-at-least-32-characters-long
  datasource:
    password: your-local-postgres-password

openai:
  # https://platform.openai.com/api-keys — 아래 값을 실제 키로만 교체 (your-openai-api-key-here 는 그대로 두면 비활성)
  api-key: your-openai-api-key-here
  # PRD/UI 생성에 쓰는 채팅 모델 (선택, 기본은 application.yml 의 gpt-4o-mini)
  # prototype-model: gpt-4o-mini

# GitHub 없이 Vercel로 직접 배포합니다.
# 비워두면 PRD는 생성되지만, 배포 URL은 시뮬레이션/결과 페이지 링크로 대체됩니다.
app:
  # PRD/프로토타입 완료 시 내려가는 prdViewUrl 용 (프론트 SPA). API 서버(8080)가 아님.
  # prd-public-base-url: http://localhost:3000
  # 로컬 디버깅 중 권한으로 막힐 때만 true (운영/공용 환경에서는 절대 true 금지)
  local-dev-permit-all-workspace-access: true
  prototype:
    # Vercel Token (현재는 이 값으로 API 배포 수행)
    # vercel-token: your-vercel-token
    # 팀 사용 시 team id (선택)
    # vercel-team-id: team_xxx
